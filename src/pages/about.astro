---
import BaseLayout from '../layouts/BaseLayout.astro';
import CertCarousel from '../components/CertCarousel.astro';

const aboutCerts = [
  { src: '/images/certs-new/Nasal Strips-CE-Analysis Certificate.gif', title: 'Nasal Strips CE' },
  { src: '/images/certs-new/Nasal Strips-Reach-Analysis Certificate.gif', title: 'Nasal Strips REACH' },
  { src: '/images/certs-new/Nasal Strips-Testing Certificate.gif', title: 'Testing Certificate' },
  { src: '/images/certs-new/Mouthtape-CE-Analysis Certificate.gif', title: 'Mouth Tape CE' },
  { src: '/images/certs-new/Mouthtape-Reach-Analysis Certificate.gif', title: 'Mouth Tape REACH' },
  { src: '/images/certs-new/Mouthtape-Nasal Strips-MSDS-Analysis Certificate.gif', title: 'MSDS Analysis' },
  { src: '/images/certs-new/Adhesive-SGS-Analysis Certificate.gif', title: 'SGS Analysis' },
  { src: '/images/certs-new/CollagenMouthtape-COA.gif', title: 'COA Certificate' },
  { src: '/images/certs-new/sgs.png', title: 'SGS Certified' },
];
---

<BaseLayout
  title="About HLK Nasal Strips — 20+ Years Manufacturing Excellence | Factory & OEM"
  description="Quanzhou Honglinkai New Material Co., Ltd. — a leading nasal strip manufacturer in China with 5,000m² facility, FDA/CE/ISO 13485 certified. 20+ years of adhesive technology expertise."
>
  <section class="page-header" style="--page-header-bg: url('/images/factory-banner-1.jpg') center/cover no-repeat;">
    <div class="container">
      <h1>About HLK</h1>
      <p>The manufacturing partner behind successful nasal strip brands worldwide.</p>
    </div>
  </section>

  <!-- ===== Company Story ===== -->
  <section class="section">
    <div class="container">
      <div class="product-grid">
        <img src="/images/HLK_Lifestyle_Female_Model.jpg" alt="HLK Factory & Product" loading="lazy" style="width: 100%; height: auto; border-radius: var(--radius-xl); min-height: 350px; object-fit: cover;" />
        <div>
          <h2>20+ Years of Adhesive Technology</h2>
          <p>Quanzhou Honglinkai New Material Co., Ltd. (HLK) was founded in 2005 with a single mission: to produce the world's most reliable adhesive products for health and wellness applications.</p>
          <p>What started as a small tape manufacturing workshop has grown into a 5,000m&sup2; modern production facility equipped with automated production lines, in-house R&amp;D laboratory, and a dedicated quality control team.</p>
          <p>Today, HLK ships to 30+ countries across the US, EU, South America, Middle East, and Asia-Pacific. We are the trusted OEM partner for brands sold in Walmart, CVS, Amazon, and pharmacy chains worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Facility ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Our Manufacturing Facility</h2>
      <p class="section-subtitle">State-of-the-art production lines with strict quality management.</p>

      <div class="factory-stats">
        <div class="stat-item">
          <div class="stat-number">5,000</div>
          <div class="stat-label">m² Production Base</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5</div>
          <div class="stat-label">Automated Lines</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">2M+</div>
          <div class="stat-label">Monthly Capacity</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">30+</div>
          <div class="stat-label">Export Countries</div>
        </div>
      </div>

      <div class="factory-gallery">
        <div class="factory-item">
          <img src="/images/factory-banner-1.jpg" alt="HLK OEM ODM Manufacturing" loading="lazy" />
          <div class="factory-caption">OEM/ODM Production</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-2.jpg" alt="One-Stop Custom Tape Supplier" loading="lazy" />
          <div class="factory-caption">Full Customization</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-3.jpg" alt="HLK Product Portfolio" loading="lazy" />
          <div class="factory-caption">Product Portfolio</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-4.jpg" alt="Private Label Packaging" loading="lazy" />
          <div class="factory-caption">Private Label Packaging</div>
        </div>
      </div>

      <h3 style="text-align: center; margin: 2.5rem 0 0.5rem; font-size: 1.4rem;">See Our Factory in Action</h3>
      <p style="text-align: center; color: var(--gray-500); max-width: 600px; margin: 0 auto 1rem;">Watch our production lines and see how we make your products — from raw materials to finished packaging.</p>
      <div class="video-gallery">
        <div class="video-card">
          <div class="video-thumb" data-video-id="cfaE2a2VJ6w" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/cfaE2a2VJ6w/maxresdefault.jpg" alt="HLK Factory Production Tour" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Factory Production Line Tour — See How We Manufacture</div>
        </div>
        <div class="video-card">
          <div class="video-thumb" data-video-id="zjVHvVEgJTE" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/zjVHvVEgJTE/maxresdefault.jpg" alt="HLK Quality Control & Packaging" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Quality Control & Packaging — From Inspection to Shipment</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Certifications ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Certifications</h2>
      <p class="section-subtitle">Quality, safety, and compliance — verified by international authorities.</p>

      <CertCarousel certs={aboutCerts} />

      <div style="margin-top: 2.5rem; text-align: center;">
        <a href="/contact" class="btn btn-outline btn-lg">Request Full Certification Documents</a>
      </div>
    </div>
  </section>

  <!-- ===== Quality Control Process ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Our 6-Step Quality Control Process</h2>
      <p class="section-subtitle">Every batch goes through rigorous testing — from raw material inspection to final shipment approval.</p>

      <div class="grid-3" style="margin-top: 2.5rem;">
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">1</div>
            <h4 style="margin: 0;">Raw Material Inspection</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Every incoming batch of non-woven fabric, PET bands, and adhesive is tested for tensile strength, thickness uniformity, and chemical composition before entering production.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">2</div>
            <h4 style="margin: 0;">In-Process Monitoring</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Automated sensors continuously monitor cutting precision, adhesive application thickness, and spring-band tension during production. Any deviation triggers immediate line stoppage.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">3</div>
            <h4 style="margin: 0;">Adhesion Strength Test</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Each batch undergoes peel-and-stick testing on multiple skin types. We verify the adhesive holds firmly for 10+ hours yet removes painlessly without residue.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">4</div>
            <h4 style="margin: 0;">Skin Safety Verification</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Dermatological testing ensures hypoallergenic performance. All products are latex-free, BPA-free, and pass ISO 10993 biocompatibility standards for skin contact.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">5</div>
            <h4 style="margin: 0;">Packaging Integrity</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Seal strength, tear resistance, and sterilization confirmation on every sachet and box. Barcode verification ensures full traceability from factory to shelf.</p>
        </div>
        <div class="card" style="padding: 1.5rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--blue-600); font-size: 1.1rem;">6</div>
            <h4 style="margin: 0;">Final Batch Release</h4>
          </div>
          <p style="font-size: 0.88rem; color: var(--gray-600);">QC manager signs off with a Certificate of Conformance (CoC). Full batch records archived for 5 years. Samples retained for post-market surveillance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Who We Serve ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Who We Serve</h2>
      <p class="section-subtitle">From emerging brands to global retail chains — we scale with your business.</p>

      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card" style="padding: 1.5rem; border-left: 4px solid var(--blue-500);">
          <h4 style="margin-bottom: 0.5rem;">E-Commerce Brands</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Amazon FBA ready packaging, custom branding, fast restocking. We help D2C brands launch and scale on Amazon, Shopify, and TikTok Shop.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--blue-600); font-weight: 600;">MOQ from 1,000 boxes</div>
        </div>
        <div class="card" style="padding: 1.5rem; border-left: 4px solid #22C55E;">
          <h4 style="margin-bottom: 0.5rem;">Pharmacy &amp; Retail Chains</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Shelf-ready display packaging, barcode-compliant labeling, regulatory documentation. Trusted by pharmacies and drugstores across the US and EU.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: #22C55E; font-weight: 600;">Full GSV available</div>
        </div>
        <div class="card" style="padding: 1.5rem; border-left: 4px solid #8B5CF6;">
          <h4 style="margin-bottom: 0.5rem;">Distributors &amp; Wholesalers</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Bulk pricing tiers, exclusive territory agreements, mixed product container loading. Long-term supply partnerships with flexible terms.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: #8B5CF6; font-weight: 600;">Volume discounts up to 35%</div>
        </div>
        <div class="card" style="padding: 1.5rem; border-left: 4px solid #F59E0B;">
          <h4 style="margin-bottom: 0.5rem;">Health &amp; Wellness Clinics</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Professional-grade products for sleep clinics, dental practices, and sports medicine. Private label with clinical packaging and dosing instructions.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: #F59E0B; font-weight: 600;">Clinical documentation provided</div>
        </div>
        <div class="card" style="padding: 1.5rem; border-left: 4px solid #EF4444;">
          <h4 style="margin-bottom: 0.5rem;">Sports &amp; Fitness Brands</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Sweat-resistant formulations, custom athletic colors, team branding. Perfect for gyms, sports teams, and fitness influencers launching product lines.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: #EF4444; font-weight: 600;">Sweat-proof adhesive tested</div>
        </div>
        <div class="card" style="padding: 1.5rem; border-left: 4px solid #06B6D4;">
          <h4 style="margin-bottom: 0.5rem;">Beauty &amp; Skincare Brands</h4>
          <p style="font-size: 0.88rem; color: var(--gray-600);">Face lifting tape, collagen-infused patches, premium packaging. We help beauty brands expand into the fast-growing face tape category.</p>
          <div style="margin-top: 0.5rem; font-size: 0.8rem; color: #06B6D4; font-weight: 600;">Beauty market expertise</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Competitive Advantages ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container" style="max-width: 900px;">
      <h2 class="section-title">Why Brands Choose HLK Over Other Suppliers</h2>
      <p class="section-subtitle">Side-by-side comparison with typical Chinese nasal strip factories.</p>

      <table class="spec-table" style="margin-top: 2rem;">
        <tr><th style="width: 35%;">Capability</th><th style="width: 32.5%; color: var(--blue-600);">HLK</th><th style="width: 32.5%; color: var(--gray-400);">Typical Factory</th></tr>
        <tr><td>Years in adhesive manufacturing</td><td><strong>20+ years</strong></td><td>5-10 years</td></tr>
        <tr><td>Production facility size</td><td><strong>5,000m²</strong></td><td>1,000-2,000m²</td></tr>
        <tr><td>Monthly capacity</td><td><strong>2M+ pieces</strong></td><td>500K-1M</td></tr>
        <tr><td>Certifications</td><td><strong>FDA, CE MDR, ISO 13485, SGS, RoHS, REACH, EPR</strong></td><td>1-2 certs only</td></tr>
        <tr><td>OEM sample turnaround</td><td><strong>3-5 days</strong></td><td>7-14 days</td></tr>
        <tr><td>Bulk production lead time</td><td><strong>7-15 days</strong></td><td>20-30 days</td></tr>
        <tr><td>Dedicated account manager</td><td><strong>Yes, English-speaking</strong></td><td>Sales rep shared</td></tr>
        <tr><td>Custom formulation (herbal, collagen)</td><td><strong>Yes, in-house R&D</strong></td><td>Limited / outsourced</td></tr>
        <tr><td>Quality documentation (CoC, MSDS)</td><td><strong>Provided with every shipment</strong></td><td>Extra cost / on request</td></tr>
      </table>
    </div>
  </section>

  <!-- ===== TESTIMONIALS / CUSTOMER VISITS ===== -->
  <section class="section testimonials-section">
    <div class="container">
      <h2 class="section-title">Trusted by 900+ Global Buyers</h2>
      <p class="section-subtitle">Join 900+ satisfied customers across 30+ countries who visited our facility and trust HLK for their supply chain.</p>

      <div class="testimonials-grid">
        <!-- Testimonial 1: US -->
        <div class="testimonial-card">
          <div class="testimonial-photo-wrap">
            <img src="/images/kh/Michael-Peterson.jpg" alt="Michael Peterson visiting HLK factory" loading="lazy" />
            <div class="testimonial-visit-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Factory Visit
            </div>
            <div class="testimonial-country-flag">🇺🇸</div>
          </div>
          <div class="testimonial-body">
            <div class="testimonial-stars">
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            </div>
            <p class="testimonial-quote">Visited the facility in person before placing our first order. The production lines are clean and organized, QC is thorough. We've been working with HLK for 18 months now — consistent quality every batch.</p>
            <div class="testimonial-meta">
              <div class="testimonial-avatar-placeholder">MP</div>
              <div class="testimonial-info">
                <div class="testimonial-name">Michael Peterson</div>
                <div class="testimonial-role">Procurement Manager</div>
                <div class="testimonial-company">BreatheWell Inc., USA</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Testimonial 2: Netherlands -->
        <div class="testimonial-card">
          <div class="testimonial-photo-wrap">
            <img src="/images/kh/20260320042030_1272_49.jpg" alt="Customer group visit to HLK factory" loading="lazy" />
            <div class="testimonial-visit-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Factory Visit
            </div>
            <div class="testimonial-country-flag">🇳🇱</div>
          </div>
          <div class="testimonial-body">
            <div class="testimonial-stars">
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            </div>
            <p class="testimonial-quote">As a European distributor, regulatory compliance is everything for us. HLK's CE MDR and ISO 13485 certifications are genuine and well-documented. Their team speaks fluent English which makes communication seamless.</p>
            <div class="testimonial-meta">
              <div class="testimonial-avatar-placeholder">JV</div>
              <div class="testimonial-info">
                <div class="testimonial-name">Jan Vermeer</div>
                <div class="testimonial-role">CEO &amp; Founder</div>
                <div class="testimonial-company">EuroHealth Supply B.V., Netherlands</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Testimonial 3: Brazil -->
        <div class="testimonial-card">
          <div class="testimonial-photo-wrap">
            <img src="/images/factory-banner-3.jpg" alt="Customer visit — HLK production line tour" loading="lazy" />
            <div class="testimonial-visit-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Factory Visit
            </div>
            <div class="testimonial-country-flag">🇧🇷</div>
          </div>
          <div class="testimonial-body">
            <div class="testimonial-stars">
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
              <svg class="testimonial-star" viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.28 5.23 15.71l.91-5.32L2.27 6.62l5.34-.78L10 1z"/></svg>
            </div>
            <p class="testimonial-quote">We import nasal strips in bulk for the Brazilian market. HLK offers competitive pricing without sacrificing quality. The DDP shipping option to São Paulo saves us a lot on logistics. Highly recommended for South American buyers.</p>
            <div class="testimonial-meta">
              <div class="testimonial-avatar-placeholder">LS</div>
              <div class="testimonial-info">
                <div class="testimonial-name">Luciana Santos</div>
                <div class="testimonial-role">Import Director</div>
                <div class="testimonial-company">VidaSaúde Brasil Ltda., Brazil</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Testimonial 4: Australia -->
