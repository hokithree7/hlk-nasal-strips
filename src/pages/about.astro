---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About HLK Nasal Strips — 20+ Years Manufacturing Excellence | Factory & OEM"
  description="Quanzhou Honglinkai New Material Co., Ltd. — a leading nasal strip manufacturer in China with 5,000m² facility, FDA/CE/ISO 13485 certified. 20+ years of adhesive technology expertise."
>
  <section class="page-header">
    <div class="container">
      <h1>About HLK</h1>
      <p>The manufacturing partner behind successful nasal strip brands worldwide.</p>
    </div>
  </section>

  <!-- ===== Company Story ===== -->
  <section class="section">
    <div class="container">
      <div class="product-grid">
        <img src="/images/HLK_Lifestyle_Female_Model.jpg" alt="HLK Factory & Product" loading="lazy" style="width: 100%; height: auto; border-radius: var(--radius-xl); min-height: 350px; object-fit: cover;" />
        <div>
          <h2>20+ Years of Adhesive Technology</h2>
          <p>Quanzhou Honglinkai New Material Co., Ltd. (HLK) was founded in 2005 with a single mission: to produce the world's most reliable adhesive products for health and wellness applications.</p>
          <p>What started as a small tape manufacturing workshop has grown into a 5,000m&sup2; modern production facility equipped with automated production lines, in-house R&amp;D laboratory, and a dedicated quality control team.</p>
          <p>Today, HLK ships to 30+ countries across the US, EU, South America, Middle East, and Asia-Pacific. We are the trusted OEM partner for brands sold in Walmart, CVS, Amazon, and pharmacy chains worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Facility ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Our Manufacturing Facility</h2>
      <p class="section-subtitle">State-of-the-art production lines with strict quality management.</p>

      <div class="factory-stats">
        <div class="stat-item">
          <div class="stat-number">5,000</div>
          <div class="stat-label">m² Production Base</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5</div>
          <div class="stat-label">Automated Lines</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">2M+</div>
          <div class="stat-label">Monthly Capacity</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">30+</div>
          <div class="stat-label">Export Countries</div>
        </div>
      </div>

      <div class="factory-gallery">
        <div class="factory-item">
          <img src="/images/factory-banner-1.jpg" alt="HLK OEM ODM Manufacturing" loading="lazy" />
          <div class="factory-caption">OEM/ODM Production</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-2.jpg" alt="One-Stop Custom Tape Supplier" loading="lazy" />
          <div class="factory-caption">Full Customization</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-3.jpg" alt="HLK Product Portfolio" loading="lazy" />
          <div class="factory-caption">Product Portfolio</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-4.jpg" alt="Private Label Packaging" loading="lazy" />
          <div class="factory-caption">Private Label Packaging</div>
        </div>
      </div>

      <div class="vr-tour-card" style="margin-top: 2rem; grid-column: 1 / -1;">
        <div class="vr-badge">VR Showroom Available</div>
        <h3>Take a Virtual Factory Tour</h3>
        <p>Explore our production facility in 360° through our Alibaba Virtual Reality Showroom. See our workshop, equipment, and quality control process from anywhere.</p>
        <a href="https://cnhlk.en.alibaba.com/" target="_blank" rel="noopener" class="btn btn-white">Launch VR Showroom on Alibaba &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ===== Certifications ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our Certifications</h2>
      <p class="section-subtitle">Quality, safety, and compliance — verified by international authorities.</p>

      <div class="cert-gallery-grid" style="margin-top: 2rem;">
        <div class="cert-gallery-item">
          <img class="cert-lightbox-trigger cert-thumb" src="/images/cert-ce.jpg" alt="CE Marked — EU Medical Device Regulation MDR 2017/745" data-full="/images/cert-ce.jpg" />
          <div class="cert-info">
            <h4>CE Marked</h4>
            <p>EU Medical Device Regulation (MDR 2017/745). Free sale across the European Union. Cert No. TST20240303098-3RC.</p>
          </div>
        </div>
        <div class="cert-gallery-item">
          <img class="cert-lightbox-trigger cert-thumb" src="/images/cert-rohs.jpg" alt="RoHS Compliant — Restriction of Hazardous Substances" data-full="/images/cert-rohs.jpg" />
          <div class="cert-info">
            <h4>RoHS Compliant</h4>
            <p>All raw materials are RoHS-compliant, ensuring no hazardous substances are present in our products. Cert No. BSTDGF526245241010381HC.</p>
          </div>
        </div>
        <div class="cert-gallery-item">
          <img class="cert-lightbox-trigger cert-thumb" src="/images/cert-epr-de.jpg" alt="EPR Germany — Packaging Registration" data-full="/images/cert-epr-de.jpg" />
          <div class="cert-info">
            <h4>EPR Germany</h4>
            <p>Extended Producer Responsibility registered for German packaging compliance. Reg No. DE1848439896773.</p>
          </div>
        </div>
      </div>

      <div class="cert-grid" style="margin-top: 2.5rem;">
        <div class="cert-badge">
          <div class="cert-icon">FDA</div>
          <div class="cert-name">FDA Registered</div>
        </div>
        <div class="cert-badge">
          <div class="cert-icon">ISO</div>
          <div class="cert-name">ISO 13485</div>
        </div>
        <div class="cert-badge">
          <div class="cert-icon">SGS</div>
          <div class="cert-name">SGS Tested</div>
        </div>
        <div class="cert-badge">
          <div class="cert-icon" style="font-size: 1.6rem;">REACH</div>
          <div class="cert-name">REACH Compliant</div>
        </div>
        <div class="cert-badge">
          <div class="cert-icon" style="font-size: 1.6rem;">MSDS</div>
          <div class="cert-name">MSDS Available</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <h2>Visit Our Factory or Request Samples</h2>
    <p>We welcome factory visits and third-party audits. Let's discuss how we can support your business.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-white btn-lg">Contact Our Team</a>
      <a href="https://wa.me/8619559068109" target="_blank" rel="noopener" class="btn btn-outline btn-lg" style="border-color: rgba(255,255,255,0.5); color: white;">WhatsApp</a>
    </div>
  </section>
</BaseLayout>
