<script is:inline>
  // Active section highlighting on scroll
  (function() {
    const links = document.querySelectorAll('.prod-cat-link');
    const sections = ['nasal-strips', 'mouth-tape', 'sleep-patch', 'face-tape', 'sports-tape']
      .map(id => document.getElementById(id))
      .filter(Boolean);

    if (!links.length || !sections.length) return;

    function updateActive() {
      const navBottom = document.querySelector('.prod-cat-nav')?.getBoundingClientRect().bottom || 100;
      let current = sections[0];
      for (const sec of sections) {
        const rect = sec.getBoundingClientRect();
        if (rect.top <= navBottom + 20) {
          current = sec;
        }
      }
      links.forEach(link => {
        const isActive = link.getAttribute('href') === '#' + current.id;
        link.classList.toggle('prod-cat-link--active', isActive);
      });
    }

    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    updateActive();
  })();
</script>
