---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Nasal Strips — Specifications, Pricing & Custom Options | HLK"
  description="Browse HLK nasal strip product line: classic, sports, and custom. Full specifications, OEM options, MOQ, and packaging details. Factory-direct wholesale pricing."
>
  <!-- ===== Page Header ===== -->
  <section class="page-header">
    <div class="container">
      <h1>Nasal Strip Products</h1>
      <p>Medical-grade nasal strips manufactured in our FDA-registered, ISO 13485 certified facility.</p>
    </div>
  </section>

  <!-- ===== Classic Nasal Strips ===== -->
  <section class="section">
    <div class="container">
      <div class="product-grid">
        <div class="product-image" style="background: linear-gradient(135deg, #E3F2FD, #BBDEFB); min-height: 380px; display: flex; align-items: center; justify-content: center; font-size: 6rem;">
          🫁
        </div>
        <div>
          <span class="badge badge-blue" style="margin-bottom: 1rem;">Bestseller</span>
          <h2 style="margin-bottom: 0.75rem;">Classic Nasal Strips</h2>
          <p style="margin-bottom: 1rem;">Our most popular product, trusted by leading brands worldwide. Dual spring-action bands with medical-grade hypoallergenic adhesive that gently lifts nasal passages for improved airflow.</p>

          <h3 style="font-size: 1.1rem; margin-bottom: 0.75rem;">Specifications</h3>
          <table class="spec-table">
            <tr><th>Material</th><td>Non-woven fabric + PET spring bands</td></tr>
            <tr><th>Adhesive</th><td>Medical-grade acrylic, hypoallergenic</td></tr>
            <tr><th>Sizes</th><td>Medium (55mm x 16mm), Large (66mm x 19mm)</td></tr>
            <tr><th>Colors</th><td>Clear, Tan, Custom (Pantone match)</td></tr>
            <tr><th>Packaging</th><td>Individual sachet, 10/30/50/100 pcs per box</td></tr>
            <tr><th>Certifications</th><td>FDA, CE, ISO 13485, SGS, RoHS</td></tr>
            <tr><th>MOQ</th><td>1,000 boxes (custom packaging / 5,000 boxes)</td></tr>
            <tr><th>Lead Time</th><td>Samples 3-5 days / Bulk 7-15 days</td></tr>
          </table>

          <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/contact" class="btn btn-primary">Get Quotation</a>
            <a href="/oem" class="btn btn-outline">Custom Options</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Sports Strips ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <div class="product-grid">
        <div>
          <span class="badge badge-teal" style="margin-bottom: 1rem;">Popular</span>
          <h2 style="margin-bottom: 0.75rem;">Sports Performance Strips</h2>
          <p style="margin-bottom: 1rem;">Engineered for athletes and fitness enthusiasts. Extra-strong adhesive withstands intense sweat and movement. Ultra-breathable material ensures comfort during extended wear.</p>

          <h3 style="font-size: 1.1rem; margin-bottom: 0.75rem;">Specifications</h3>
          <table class="spec-table">
            <tr><th>Material</th><td>Breathable non-woven + reinforced spring</td></tr>
            <tr><th>Adhesive</th><td>Extra-strength sweat-resistant acrylic</td></tr>
            <tr><th>Sizes</th><td>Standard, Large</td></tr>
            <tr><th>Colors</th><td>Black, Blue, Neon, Custom</td></tr>
            <tr><th>Packaging</th><td>10/30/50 pcs per box</td></tr>
            <tr><th>Certifications</th><td>FDA, CE, ISO 13485</td></tr>
            <tr><th>MOQ</th><td>1,000 boxes</td></tr>
            <tr><th>Lead Time</th><td>Samples 3-5 days / Bulk 7-15 days</td></tr>
          </table>

          <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/contact" class="btn btn-primary">Get Quotation</a>
            <a href="/oem" class="btn btn-outline">Custom Options</a>
          </div>
        </div>
        <div class="product-image" style="background: linear-gradient(135deg, #E3F2FD, #90CAF9); min-height: 380px; display: flex; align-items: center; justify-content: center; font-size: 6rem;">
          🏃
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Custom / Private Label ===== -->
  <section class="section">
    <div class="container">
      <div class="product-grid">
        <div class="product-image" style="background: linear-gradient(135deg, #ECFDF5, #A7F3D0); min-height: 380px; display: flex; align-items: center; justify-content: center; font-size: 6rem;">
          ✨
        </div>
        <div>
          <span class="badge badge-green" style="margin-bottom: 1rem;">Customizable</span>
          <h2 style="margin-bottom: 0.75rem;">Custom Private Label Nasal Strips</h2>
          <p style="margin-bottom: 1rem;">Everything is negotiable. We develop nasal strips to your exact specifications — from adhesive formulation to packaging artwork. Your brand, built by the experts.</p>

          <h3 style="font-size: 1.1rem; margin-bottom: 0.75rem;">What We Can Customize</h3>
          <table class="spec-table">
            <tr><th>Strip Size</th><td>Any dimensions — pediatric to extra-large</td></tr>
            <tr><th>Adhesive Strength</th><td>Gentle to extra-strong for sports</td></tr>
            <tr><th>Material</th><td>Non-woven, transparent film, fabric</td></tr>
            <tr><th>Color</th><td>Any Pantone color, multi-color</td></tr>
            <tr><th>Packaging</th><td>Box design, sachet, blister, retail display</td></tr>
            <tr><th>Formulation</th><td>Add menthol, lavender, or other ingredients</td></tr>
            <tr><th>MOQ</th><td>5,000 boxes for custom packaging</td></tr>
            <tr><th>Sample Fee</th><td>Refundable on first order</td></tr>
          </table>

          <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
            <a href="/contact" class="btn btn-primary">Start Your Project</a>
            <a href="/oem" class="btn btn-outline">OEM Process</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Packaging Options ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Packaging Options</h2>
      <p class="section-subtitle">Flexible packaging solutions for every retail channel.</p>

      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">📦</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Individual Sachet</h3>
          <p style="font-size: 0.9rem;">Single-use foil sachet. Best for pharmacy &amp; drugstore retail. 10/30/50 per box.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🎁</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Retail Display Box</h3>
          <p style="font-size: 0.9rem;">Counter-top display with peg hole. Full-color custom print. 12/24/48 units.</p>
        </div>
        <div class="card" style="text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🏪</div>
          <h3 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Club / Bulk Pack</h3>
          <p style="font-size: 0.9rem;">100+ count value packs for warehouse clubs and subscription box channels.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <h2>Find the Right Nasal Strip for Your Market</h2>
    <p>Not sure which product fits your target customers? Let us help you select the right specification, packaging, and pricing tier.</p>
    <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="/contact" class="btn btn-white btn-lg">Get Expert Recommendation</a>
      <a href="https://wa.me/8619559068109" target="_blank" rel="noopener" class="btn btn-outline btn-lg" style="border-color: rgba(255,255,255,0.5); color: white;">WhatsApp Us</a>
    </div>
  </section>
</BaseLayout>
