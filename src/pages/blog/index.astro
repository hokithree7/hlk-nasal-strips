---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout
  title="Blog — Nasal Strips Industry Insights & Market Intelligence | HLK"
  description="Expert articles on nasal strip manufacturing, OEM importing, market trends, retailer guides, and breathing health. Written for B2B buyers and brand owners."
  keywords="nasal strips blog, OEM guide, mouth tape insights, sleep wellness, B2B manufacturer articles, adhesive patch market trends, import guide nasal strips"
>
  <section class="page-header">
    <div class="container">
      <h1>Industry Insights</h1>
      <p>Market intelligence and expert guides for nasal strip buyers, importers, and brand owners.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(post => (
          <div class="blog-card">
            <img
              src={post.data.cover || '/images/1 (1).jpg'}
              alt={post.data.title}
              loading="lazy"
              class="blog-card-image"
              style="object-fit: cover;"
            />
            <div class="blog-card-body">
              <div style="margin-bottom: 0.5rem;">
                <span class="badge badge-blue" style="font-size: 0.7rem;">{post.data.category}</span>
              </div>
              <h3>
                <a href={`/blog/${post.id}`} style="color: var(--gray-900);">
                  {post.data.title}
                </a>
              </h3>
              <p>{post.data.excerpt}</p>
              <div class="blog-card-meta">
                <span>{post.data.date}</span>
                <span>{post.data.readTime}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
