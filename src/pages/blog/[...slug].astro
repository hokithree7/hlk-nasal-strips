---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | HLK Blog`}
  description={post.data.excerpt}
>
  {post.data.cover && (
    <section style="padding: 0; margin: 0;">
      <div style="width: 100%; height: 360px; overflow: hidden; position: relative;">
        <img
          src={post.data.cover}
          alt={post.data.title}
          style="width: 100%; height: 100%; object-fit: cover;"
        />
        <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.5) 100%);"></div>
      </div>
    </section>
  )}

  <section class="page-header" style={post.data.cover ? 'background: var(--gray-900); color: white;' : ''}>
    <div class="container" style={post.data.cover ? 'max-width: 760px;' : ''}>
      <span class="badge badge-blue" style="margin-bottom: 1rem;">{post.data.category}</span>
      <h1>{post.data.title}</h1>
      <p>{post.data.date}{post.data.readTime && ` &middot; ${post.data.readTime}`}</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 760px;">
      <div class="prose" style="font-size: 1.05rem; line-height: 1.85; color: var(--gray-700);">
        <Content />
      </div>

      <div style="margin-top: 3rem; padding: 2rem; background: var(--gray-50); border-radius: var(--radius-lg); text-align: center;">
        <h3 style="margin-bottom: 0.5rem;">Ready to Source Nasal Strips?</h3>
        <p style="margin-bottom: 1.25rem;">Get a factory-direct quote within 24 hours. Free samples available.</p>
        <a href="/contact" class="btn btn-primary btn-lg">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
