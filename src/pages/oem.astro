---
import BaseLayout from '../layouts/BaseLayout.astro';
import CertCarousel from '../components/CertCarousel.astro';

const oemCerts = [
  { src: '/images/certs-new/Nasal Strips-CE-Analysis Certificate.gif', title: 'Nasal Strips CE' },
  { src: '/images/certs-new/Nasal Strips-Reach-Analysis Certificate.gif', title: 'Nasal Strips REACH' },
  { src: '/images/certs-new/Nasal Strips-Testing Certificate.gif', title: 'Testing Certificate' },
  { src: '/images/certs-new/Mouthtape-CE-Analysis Certificate.gif', title: 'Mouth Tape CE' },
  { src: '/images/certs-new/Mouthtape-Reach-Analysis Certificate.gif', title: 'Mouth Tape REACH' },
  { src: '/images/certs-new/Mouthtape-Nasal Strips-MSDS-Analysis Certificate.gif', title: 'MSDS Analysis' },
  { src: '/images/certs-new/Adhesive-SGS-Analysis Certificate.gif', title: 'SGS Analysis' },
  { src: '/images/certs-new/CollagenMouthtape-COA.gif', title: 'COA Certificate' },
  { src: '/images/certs-new/sgs.png', title: 'SGS Certified' },
];
---

<BaseLayout
  title="OEM Nasal Strips — Custom Manufacturing & Private Label | HLK"
  description="Complete OEM/ODM nasal strip manufacturing. Custom sizes, adhesives, packaging, and formulations. Low MOQ, fast samples. Start your own nasal strip brand with HLK."
>
  <section class="page-header" style="--page-header-bg: url('/images/factory-banner-2.jpg') center/cover no-repeat;">
    <div class="container">
      <h1>OEM &amp; Custom Manufacturing</h1>
      <p>Turn your nasal strip idea into a market-ready product — backed by 20 years of manufacturing expertise.</p>
    </div>
  </section>

  <!-- ===== OEM Process ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Our OEM Process</h2>
      <p class="section-subtitle">A proven 4-step workflow that gets your product to market efficiently.</p>

      <div class="grid-2" style="margin-top: 2.5rem; gap: 3rem;">
        <div>
          <div style="display: flex; gap: 1rem; margin-bottom: 2.5rem;">
            <div style="min-width: 48px; height: 48px; border-radius: 12px; background: var(--blue-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">1</div>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.4rem;">Requirement Analysis</h3>
              <p style="font-size: 0.9rem; color: var(--gray-500);">Share your vision — target market, price point, desired features. We'll recommend the optimal material, adhesive, and sizing combination based on 20 years of R&amp;D data.</p>
            </div>
          </div>
          <div style="display: flex; gap: 1rem; margin-bottom: 2.5rem;">
            <div style="min-width: 48px; height: 48px; border-radius: 12px; background: var(--teal-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">2</div>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.4rem;">Sample Development</h3>
              <p style="font-size: 0.9rem; color: var(--gray-500);">We produce 3-5 prototype versions within 5 business days. Test adhesion, comfort, and breathability. Refine until it meets your standards.</p>
            </div>
          </div>
        </div>
        <div>
          <div style="display: flex; gap: 1rem; margin-bottom: 2.5rem;">
            <div style="min-width: 48px; height: 48px; border-radius: 12px; background: var(--green-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">3</div>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.4rem;">Mass Production &amp; QC</h3>
              <p style="font-size: 0.9rem; color: var(--gray-500);">Once approved, we move to production. Every batch passes: adhesion test, skin irritation test, dimensional check, packaging integrity check. ISO 13485 standard.</p>
            </div>
          </div>
          <div style="display: flex; gap: 1rem; margin-bottom: 2.5rem;">
            <div style="min-width: 48px; height: 48px; border-radius: 12px; background: var(--amber-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem;">4</div>
            <div>
              <h3 style="font-size: 1.1rem; margin-bottom: 0.4rem;">Delivery &amp; Ongoing Support</h3>
              <p style="font-size: 0.9rem; color: var(--gray-500);">We arrange shipping to your door (FOB/CIF/DDP). After delivery, your account manager stays in touch for reorders, new product development, and market feedback.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== What We Can Do ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">What You Can Customize</h2>
      <p class="section-subtitle">Nearly every aspect of the product is under your control.</p>

      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Product Parameters</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; Strip dimensions (any size)</li>
            <li style="padding: 0.3rem 0;">&#10003; Adhesive strength level</li>
            <li style="padding: 0.3rem 0;">&#10003; Spring band tension</li>
            <li style="padding: 0.3rem 0;">&#10003; Fabric material &amp; color</li>
            <li style="padding: 0.3rem 0;">&#10003; Add menthol / essential oils</li>
            <li style="padding: 0.3rem 0;">&#10003; Breathability level</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Packaging &amp; Branding</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; Box artwork &amp; design</li>
            <li style="padding: 0.3rem 0;">&#10003; Sachet / blister / tray</li>
            <li style="padding: 0.3rem 0;">&#10003; Retail display boxes</li>
            <li style="padding: 0.3rem 0;">&#10003; Instruction inserts</li>
            <li style="padding: 0.3rem 0;">&#10003; UPC / EAN barcodes</li>
            <li style="padding: 0.3rem 0;">&#10003; Eco-friendly options</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Compliance Support</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; FDA 510(k) documentation</li>
            <li style="padding: 0.3rem 0;">&#10003; CE technical file</li>
            <li style="padding: 0.3rem 0;">&#10003; ISO 13485 certification</li>
            <li style="padding: 0.3rem 0;">&#10003; SGS test reports</li>
            <li style="padding: 0.3rem 0;">&#10003; MSDS &amp; COA documents</li>
            <li style="padding: 0.3rem 0;">&#10003; Country-specific compliance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Product Customization Steps ===== -->
  <section class="section" style="background: linear-gradient(180deg, var(--white) 0%, var(--gray-50) 100%);">
    <div class="container">
      <h2 class="section-title">Product Customization Steps</h2>
      <p class="section-subtitle">From material selection to finished packaging — every detail is under your control.</p>

      <div class="custom-steps-grid">
        <!-- Step 1 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">1</div>
            <img src="/images/1.jpg" alt="Choose Material — Non-woven, Satin, PE options" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Material</h4>
            <p><strong>Non-woven fabric</strong> — soft, breathable, eco-friendly. <strong>Satin</strong> — smooth, silky, glossy finish. <strong>PE</strong> — waterproof, durable, invisible on skin. Pick the base that matches your brand positioning.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">2</div>
            <img src="/images/2.jpg" alt="Choose Shape & Size — custom dimensions and shapes" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Shape &amp; Size</h4>
            <p>Standard sizes (S/M/L/XL) or fully custom dimensions. Special shapes for kids, athletes, or medical use. We cut dies to your exact specification with no extra tooling fee for orders over 5,000 units.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">3</div>
            <img src="/images/3.jpg" alt="Customize Colors & Logo — Pantone matching and printing" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Customize Colors &amp; Logo</h4>
            <p>15+ stock colors available. Positioning printing or full-color backing paper circular printing. Pantone matching for brand consistency. Add your logo on every strip and box.</p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">4</div>
            <img src="/images/4.jpg" alt="Choose Packaging — PET bags, paper boxes, tin boxes" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Packaging</h4>
            <p>PET bags, paper boxes, tin boxes, or display cartons. We design artwork in-house or work with your designer. FSC-certified eco packaging available for sustainability-focused brands.</p>
          </div>
        </div>
      </div>

      <!-- Additional options -->
      <div class="oem-additional-options">
        <div class="oem-additional-option">
          <div class="addon-icon">🌿</div>
          <h5>Herbal Fragrance</h5>
          <p>Lavender, chamomile, eucalyptus, mint, and more</p>
        </div>
        <div class="oem-additional-option">
          <div class="addon-icon">✨</div>
          <h5>Collagen</h5>
          <p>Infused strips for skincare synergy</p>
        </div>
        <div class="oem-additional-option">
          <div class="addon-icon">💧</div>
          <h5>Hydrogel</h5>
          <p>Cooling, soothing gel-based patches</p>
        </div>
        <div class="oem-additional-option">
          <div class="addon-icon">⚙️</div>
          <h5>More Custom</h5>
          <p>Tell us your idea — we make it real</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Production & Certification ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Production & Certification</h2>
      <p class="section-subtitle">Real factory capacity, real certificates, real compliance — everything you need to launch with confidence.</p>

      <div class="factory-stats" style="margin-bottom: 2.5rem;">
        <div class="stat-item">
          <div class="stat-number">5,000</div>
          <div class="stat-label">m² Production Base</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5</div>
          <div class="stat-label">Automated Lines</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">2M+</div>
          <div class="stat-label">Monthly Capacity</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">3-5</div>
          <div class="stat-label">Days for Samples</div>
        </div>
      </div>

      <div class="factory-gallery">
        <div class="factory-item">
          <img src="/images/factory-banner-1.jpg" alt="HLK OEM ODM Manufacturing" loading="lazy" />
          <div class="factory-caption">OEM/ODM Production</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-2.jpg" alt="One-Stop Custom Tape Supplier" loading="lazy" />
          <div class="factory-caption">Full Customization</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-3.jpg" alt="HLK Product Portfolio" loading="lazy" />
          <div class="factory-caption">Product Portfolio</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-4.jpg" alt="Private Label Packaging" loading="lazy" />
          <div class="factory-caption">Private Label Packaging</div>
        </div>
      </div>

      <h3 style="text-align: center; margin: 2.5rem 0 0.5rem; font-size: 1.4rem;">See Our Factory in Action</h3>
      <p style="text-align: center; color: var(--gray-500); max-width: 600px; margin: 0 auto 1rem;">Watch our production lines and see how we make your products — from raw materials to finished packaging.</p>
      <div class="video-gallery">
        <div class="video-card">
          <div class="video-thumb" data-video-id="cfaE2a2VJ6w" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/cfaE2a2VJ6w/maxresdefault.jpg" alt="HLK Factory Production Tour" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Factory Production Line Tour — See How We Manufacture</div>
        </div>
        <div class="video-card">
          <div class="video-thumb" data-video-id="zjVHvVEgJTE" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/zjVHvVEgJTE/maxresdefault.jpg" alt="HLK Quality Control & Packaging" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Quality Control & Packaging — From Inspection to Shipment</div>
        </div>
      </div>

      <div style="margin-top: 2.5rem;">
        <h3 style="text-align: center; margin-bottom: 1.5rem; font-size: 1.4rem;">Certifications Available for Your Brand</h3>
        <CertCarousel certs={oemCerts} />
      </div>

      <div style="margin-top: 2.5rem; text-align: center;">
        <a href="/contact" class="btn btn-outline btn-lg">Request Full Certification Documents</a>
      </div>
    </div>
  </section>

  <!-- ===== Timeline ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Typical Project Timeline</h2>
      <p class="section-subtitle">From first contact to finished product on your shelf.</p>

      <div style="max-width: 700px; margin: 2rem auto 0;">
        <div style="display: flex; justify-content: space-between; position: relative; padding-bottom: 3rem;">
          <div style="position: absolute; top: 24px; left: 0; right: 0; height: 3px; background: var(--gray-200);"></div>
          <div style="position: absolute; top: 24px; left: 0; width: 100%; height: 3px; background: linear-gradient(90deg, var(--blue-500), var(--teal-500), var(--green-500), var(--amber-500));"></div>

          <div style="text-align: center; position: relative; z-index: 2;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--blue-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; margin: 0 auto 0.75rem;">1</div>
            <strong style="display: block; font-size: 0.85rem;">Consult</strong>
            <span style="font-size: 0.75rem; color: var(--gray-500);">1-2 days</span>
          </div>
          <div style="text-align: center; position: relative; z-index: 2;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--teal-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; margin: 0 auto 0.75rem;">2</div>
            <strong style="display: block; font-size: 0.85rem;">Sample</strong>
            <span style="font-size: 0.75rem; color: var(--gray-500);">3-5 days</span>
          </div>
          <div style="text-align: center; position: relative; z-index: 2;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--green-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; margin: 0 auto 0.75rem;">3</div>
            <strong style="display: block; font-size: 0.85rem;">Produce</strong>
            <span style="font-size: 0.75rem; color: var(--gray-500);">7-15 days</span>
          </div>
          <div style="text-align: center; position: relative; z-index: 2;">
            <div style="width: 48px; height: 48px; border-radius: 50%; background: var(--amber-500); color: white; display: flex; align-items: center; justify-content: center; font-weight: 800; margin: 0 auto 0.75rem;">4</div>
            <strong style="display: block; font-size: 0.85rem;">Ship</strong>
            <span style="font-size: 0.75rem; color: var(--gray-500);">15-30 days</span>
          </div>
        </div>
        <p style="text-align: center; color: var(--gray-500); font-size: 0.88rem; margin-top: 1rem;">Total: 4 to 7 weeks from consultation to delivery</p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <h2>Ready to Create Your Own Nasal Strip Brand?</h2>
    <p>We've helped dozens of brands launch successful nasal strip products. Tell us your idea — we'll make it happen.</p>
    <a href="/contact" class="btn btn-white btn-lg">Start Your OEM Project</a>
  </section>
</BaseLayout>
