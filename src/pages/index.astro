---
import BaseLayout from '../layouts/BaseLayout.astro';
import CertCarousel from '../components/CertCarousel.astro';

const homepageCerts = [
  { src: '/images/certs-new/Nasal Strips-CE-Analysis Certificate.gif', title: 'Nasal Strips CE' },
  { src: '/images/certs-new/Nasal Strips-Reach-Analysis Certificate.gif', title: 'Nasal Strips REACH' },
  { src: '/images/certs-new/Nasal Strips-Testing Certificate.gif', title: 'Testing Certificate' },
  { src: '/images/certs-new/Mouthtape-CE-Analysis Certificate.gif', title: 'Mouth Tape CE' },
  { src: '/images/certs-new/Mouthtape-Reach-Analysis Certificate.gif', title: 'Mouth Tape REACH' },
  { src: '/images/certs-new/Mouthtape-Nasal Strips-MSDS-Analysis Certificate.gif', title: 'MSDS Analysis' },
  { src: '/images/certs-new/Adhesive-SGS-Analysis Certificate.gif', title: 'SGS Analysis' },
  { src: '/images/certs-new/CollagenMouthtape-COA.gif', title: 'COA Certificate' },
  { src: '/images/certs-new/sgs.png', title: 'SGS Certified' },
];
---

<BaseLayout
  title="HLK Nasal Strips — Premium B2B Nasal Strip Manufacturer | OEM Factory"
  description="Professional nasal strip manufacturer with 20+ years experience. FDA, CE, ISO 13485 certified. OEM/ODM, wholesale & bulk orders. Factory-direct pricing."
>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container" style="position: relative; z-index: 2;">
      <div class="hero-content">
        <div style="display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: 50px; padding: 0.4rem 1.2rem; margin-bottom: 1.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.85);">
          <span style="display: inline-block; width: 8px; height: 8px; background: #22C55E; border-radius: 50%; box-shadow: 0 0 8px rgba(34,197,94,0.6);"></span>
          Trusted Factory Since 2005
        </div>
        <h1>Premium Nasal Strips<br/>for Global Brands</h1>
        <p>From our 5,000m&sup2; certified facility to your customers' hands — HLK delivers medical-grade nasal strips with unmatched quality, competitive pricing, and reliable supply chain management. Partner with a factory that understands your market.</p>
        <div class="hero-buttons">
          <a href="/contact" class="btn btn-white btn-lg">Request Factory Quote</a>
          <a href="/products" class="btn btn-outline" style="border-color: rgba(255,255,255,0.4); color: white;">View Product Specs</a>
        </div>
        <div style="display: flex; align-items: center; gap: 1.5rem; margin-top: 2.5rem; flex-wrap: wrap;">
          <div style="display: flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.7); font-size: 0.85rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            FDA Registered
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.7); font-size: 0.85rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            CE &amp; ISO 13485
          </div>
          <div style="display: flex; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.7); font-size: 0.85rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            MOQ 1,000 Units
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FACTORY CREDENTIALS BAR ===== -->
  <section class="factory-creds-bar">
    <div class="container">
      <div class="factory-creds-grid">
        <div class="factory-cred-item">
          <div class="factory-cred-number">20+</div>
          <div class="factory-cred-label">Years Experience</div>
        </div>
        <div class="factory-cred-divider"></div>
        <div class="factory-cred-item">
          <div class="factory-cred-number">2</div>
          <div class="factory-cred-label">R&amp;D Engineers</div>
        </div>
        <div class="factory-cred-divider"></div>
        <div class="factory-cred-item">
          <div class="factory-cred-number">4</div>
          <div class="factory-cred-label">QA/QC Inspectors</div>
        </div>
        <div class="factory-cred-divider"></div>
        <div class="factory-cred-item">
          <div class="factory-cred-number">&le;3h</div>
          <div class="factory-cred-label">Response Time</div>
        </div>
        <div class="factory-cred-divider"></div>
        <div class="factory-cred-item">
          <div class="factory-cred-number">94.8%</div>
          <div class="factory-cred-label">On-Time Delivery</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CERT & ASSURANCE ===== -->
  <section class="cert-assurance-strip">
    <div class="container">
      <div class="cert-badge-grid">
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/ce.png" alt="CE MDR 2017/745" loading="lazy" />
          </div>
          <h4>CE MDR</h4>
          <p>EU Medical Device</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/certs/02.png" alt="ISO 13485" loading="lazy" />
          </div>
          <h4>ISO 13485</h4>
          <p>Quality Management</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <svg viewBox="0 0 48 48" width="36" height="36" fill="none" stroke="#1E88E5" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M24 2L4 10v14c0 12 8.5 20.5 20 24 11.5-3.5 20-12 20-24V10L24 2z" fill="#EBF5FF"/>
              <polyline points="16 24 22 30 34 18" stroke-width="3"/>
            </svg>
          </div>
          <h4>FDA Registered</h4>
          <p>US FDA facility</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/sgs.png" alt="SGS Certified" loading="lazy" />
          </div>
          <h4>SGS Tested</h4>
          <p>Third-party verified</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/reach.png" alt="REACH Compliant" loading="lazy" />
          </div>
          <h4>REACH</h4>
          <p>EU Regulation</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/tuv.png" alt="TÜV Rheinland" loading="lazy" />
          </div>
          <h4>TÜV Rheinland</h4>
          <p>Quality Audited</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/msds.png" alt="MSDS" loading="lazy" />
          </div>
          <h4>MSDS</h4>
          <p>Safety Data Sheet</p>
        </div>
        <div class="cert-badge-card">
          <div class="cert-badge-icon">
            <img src="/images/cert-icons/pfas.png" alt="PFAS Free" loading="lazy" />
          </div>
          <h4>PFAS Free</h4>
          <p>EU compliant</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== WHY HLK (Compact) ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Why Partner With HLK?</h2>
      <p class="section-subtitle">20+ years of adhesive tape manufacturing expertise. FDA, CE, ISO 13485 certified. Your manufacturing partner, not just a supplier.</p>

      <div class="grid-3" style="margin-top: 1.5rem;">
        <div class="why-compact-card">
          <div class="why-compact-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1E88E5" stroke-width="2"><path d="M2 12h2l1-8h14l1 8h2"/><rect x="4" y="8" width="16" height="12" rx="2"/></svg>
          </div>
          <div>
            <h4>Factory-Direct Pricing</h4>
            <p>Zero middlemen. 5,000m² facility with automated lines for consistent quality at scale.</p>
          </div>
        </div>

        <div class="why-compact-card">
          <div class="why-compact-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1E88E5" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M12 8v8M8 12h8"/></svg>
          </div>
          <div>
            <h4>Complete OEM Service</h4>
            <p>Custom sizing, formulation, packaging, and design — your brand, our expertise.</p>
          </div>
        </div>

        <div class="why-compact-card">
          <div class="why-compact-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1E88E5" stroke-width="2"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h4>Global Logistics</h4>
            <p>30+ export countries. EXW, FOB, CIF, DDP — flexible terms for your supply chain.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FACTORY SHOWCASE ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Our Manufacturing Facility</h2>
      <p class="section-subtitle">5,000m² production base with automated lines, in-house R&D, and strict QC — serving global brands since 2005.</p>

      <div class="factory-stats">
        <div class="stat-item">
          <div class="stat-number">5,000</div>
          <div class="stat-label">m² Production Base</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">5</div>
          <div class="stat-label">Automated Lines</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">2M+</div>
          <div class="stat-label">Monthly Capacity</div>
        </div>
        <div class="stat-item">
          <div class="stat-number">30+</div>
          <div class="stat-label">Export Countries</div>
        </div>
      </div>

      <div class="factory-gallery">
        <div class="factory-item">
          <img src="/images/factory-banner-1.jpg" alt="HLK OEM ODM Manufacturing" loading="lazy" />
          <div class="factory-caption">OEM/ODM Production</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-2.jpg" alt="One-Stop Custom Tape Supplier" loading="lazy" />
          <div class="factory-caption">Full Customization</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-3.jpg" alt="HLK Product Portfolio" loading="lazy" />
          <div class="factory-caption">Product Portfolio</div>
        </div>
        <div class="factory-item">
          <img src="/images/factory-banner-4.jpg" alt="Private Label Packaging" loading="lazy" />
          <div class="factory-caption">Private Label Packaging</div>
        </div>
      </div>

      <h3 style="text-align: center; margin: 2.5rem 0 0.5rem; font-size: 1.4rem;">See Our Factory in Action</h3>
      <p style="text-align: center; color: var(--gray-500); max-width: 600px; margin: 0 auto 1rem;">Watch our production lines and see how we make your products — from raw materials to finished packaging.</p>
      <div class="video-gallery">
        <div class="video-card">
          <div class="video-thumb" data-video-id="cfaE2a2VJ6w" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/cfaE2a2VJ6w/maxresdefault.jpg" alt="HLK Factory Production Tour" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Factory Production Line Tour — See How We Manufacture</div>
        </div>
        <div class="video-card">
          <div class="video-thumb" data-video-id="zjVHvVEgJTE" onclick="playVideo(this)">
            <img src="https://img.youtube.com/vi/zjVHvVEgJTE/maxresdefault.jpg" alt="HLK Quality Control & Packaging" loading="lazy" />
            <div class="video-play-btn">
              <div class="video-play-icon"></div>
            </div>
          </div>
          <div class="video-title">Quality Control & Packaging — From Inspection to Shipment</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OUR NASAL STRIPS ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">Our Nasal Strip Products</h2>
      <p class="section-subtitle">Engineered for breathing performance, manufactured for brand success.</p>

      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card" style="text-align: center; overflow: hidden; padding: 0;">
          <img src="/images/1 (1).jpg" alt="Classic Nasal Strips" loading="lazy" style="width: 100%; height: 200px; object-fit: cover;" />
          <div style="padding: 1.25rem;">
            <h3 style="margin-bottom: 0.5rem;">Classic Nasal Strips</h3>
            <p style="font-size: 0.88rem;">Spring-action design, hypoallergenic adhesive. Clear, tan, or custom colors.</p>
            <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
              <span class="badge badge-blue">Bestseller</span>
              <span class="badge badge-teal">FDA</span>
            </div>
          </div>
        </div>

        <div class="card" style="text-align: center; overflow: hidden; padding: 0;">
          <img src="/images/hlk_sports_performance.jpg" alt="Sports Performance Strips" loading="lazy" style="width: 100%; height: 200px; object-fit: cover;" />
          <div style="padding: 1.25rem;">
            <h3 style="margin-bottom: 0.5rem;">Sports Performance Strips</h3>
            <p style="font-size: 0.88rem;">Extra-strong sweat-resistant adhesive. Built for intense workouts and athletes.</p>
            <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
              <span class="badge badge-teal">Sweat-Proof</span>
            </div>
          </div>
        </div>

        <div class="card" style="text-align: center; overflow: hidden; padding: 0;">
          <img src="https://s.alicdn.com/@sc04/kf/He110da726f7e49a0968e250d7884331fT.jpg" alt="Nasal Dilator Starter Kit" loading="lazy" style="width: 100%; height: 200px; object-fit: cover;" />
          <div style="padding: 1.25rem;">
            <h3 style="margin-bottom: 0.5rem;">Nasal Dilator System</h3>
            <p style="font-size: 0.88rem;">Reusable band + daily hypoallergenic patches. 30-day kit, non-magnetic design.</p>
            <div style="margin-top: 0.75rem; display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
              <span class="badge badge-teal">Reusable</span>
              <span class="badge badge-blue">Amazon-Ready</span>
            </div>
          </div>
        </div>
      </div>

      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/products" class="btn btn-primary btn-lg">View Full Specifications</a>
      </div>
    </div>
  </section>

  <!-- ===== OEM PROCESS ===== -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Your OEM Journey With HLK</h2>
      <p class="section-subtitle">Four simple steps from concept to your customers.</p>

      <div class="grid-4" style="margin-top: 2.5rem;">
        <div style="text-align: center;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.6rem; font-weight: 800; color: var(--blue-600);">1</div>
          <h4 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Consult &amp; Define</h4>
          <p style="font-size: 0.88rem; color: var(--gray-500);">Share your requirements: size, adhesion, packaging, target market. We consult on the best solution.</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.6rem; font-weight: 800; color: var(--blue-600);">2</div>
          <h4 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Sample &amp; Approve</h4>
          <p style="font-size: 0.88rem; color: var(--gray-500);">We produce samples in 3-5 days. You test, we refine. Iterate until perfect.</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.6rem; font-weight: 800; color: var(--blue-600);">3</div>
          <h4 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Produce &amp; QC</h4>
          <p style="font-size: 0.88rem; color: var(--gray-500);">Full production with strict quality control. Every batch tested before shipping.</p>
        </div>
        <div style="text-align: center;">
          <div style="width: 64px; height: 64px; border-radius: 50%; background: var(--blue-50); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; font-size: 1.6rem; font-weight: 800; color: var(--blue-600);">4</div>
          <h4 style="margin-bottom: 0.5rem; font-size: 1.1rem;">Ship &amp; Support</h4>
          <p style="font-size: 0.88rem; color: var(--gray-500);">We handle logistics to your warehouse. Ongoing support for reorders and new products.</p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 2.5rem;">
        <a href="/oem" class="btn btn-outline btn-lg">Learn About OEM</a>
      </div>
    </div>
  </section>

  <!-- ===== WHAT YOU CAN CUSTOMIZE ===== -->
  <section class="section" style="background: var(--gray-50);">
    <div class="container">
      <h2 class="section-title">What You Can Customize</h2>
      <p class="section-subtitle">Nearly every aspect of the product is under your control.</p>

      <div class="grid-3" style="margin-top: 2rem;">
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Product Parameters</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; Strip dimensions (any size)</li>
            <li style="padding: 0.3rem 0;">&#10003; Adhesive strength level</li>
            <li style="padding: 0.3rem 0;">&#10003; Spring band tension</li>
            <li style="padding: 0.3rem 0;">&#10003; Fabric material &amp; color</li>
            <li style="padding: 0.3rem 0;">&#10003; Add menthol / essential oils</li>
            <li style="padding: 0.3rem 0;">&#10003; Breathability level</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Packaging &amp; Branding</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; Box artwork &amp; design</li>
            <li style="padding: 0.3rem 0;">&#10003; Sachet / blister / tray</li>
            <li style="padding: 0.3rem 0;">&#10003; Retail display boxes</li>
            <li style="padding: 0.3rem 0;">&#10003; Instruction inserts</li>
            <li style="padding: 0.3rem 0;">&#10003; UPC / EAN barcodes</li>
            <li style="padding: 0.3rem 0;">&#10003; Eco-friendly options</li>
          </ul>
        </div>
        <div class="card">
          <h3 style="margin-bottom: 0.75rem; font-size: 1.1rem;">Compliance Support</h3>
          <ul style="list-style: none; padding: 0; font-size: 0.9rem; color: var(--gray-600);">
            <li style="padding: 0.3rem 0;">&#10003; FDA 510(k) documentation</li>
            <li style="padding: 0.3rem 0;">&#10003; CE technical file</li>
            <li style="padding: 0.3rem 0;">&#10003; ISO 13485 certification</li>
            <li style="padding: 0.3rem 0;">&#10003; SGS test reports</li>
            <li style="padding: 0.3rem 0;">&#10003; MSDS &amp; COA documents</li>
            <li style="padding: 0.3rem 0;">&#10003; Country-specific compliance</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PRODUCT CUSTOMIZATION STEPS ===== -->
  <section class="section" style="background: linear-gradient(180deg, var(--white) 0%, var(--gray-50) 100%);">
    <div class="container">
      <h2 class="section-title">Product Customization Steps</h2>
      <p class="section-subtitle">From material selection to finished packaging — every detail is under your control.</p>

      <div class="custom-steps-grid">
        <!-- Step 1 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">1</div>
            <img src="/images/1.jpg" alt="Choose Material — Non-woven, Satin, PE options" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Material</h4>
            <p><strong>Non-woven fabric</strong> — soft, breathable, eco-friendly. <strong>Satin</strong> — smooth, silky, glossy finish. <strong>PE</strong> — waterproof, durable, invisible on skin. Pick the base that matches your brand positioning.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">2</div>
            <img src="/images/2.jpg" alt="Choose Shape & Size — custom dimensions and shapes" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Shape &amp; Size</h4>
            <p>Standard sizes (S/M/L/XL) or fully custom dimensions. Special shapes for kids, athletes, or medical use. We cut dies to your exact specification with no extra tooling fee for orders over 5,000 units.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">3</div>
            <img src="/images/3.jpg" alt="Customize Colors & Logo — Pantone matching and printing" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Customize Colors &amp; Logo</h4>
            <p>15+ stock colors available. Positioning printing or full-color backing paper circular printing. Pantone matching for brand consistency. Add your logo on every strip and box.</p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="custom-step-card">
          <div class="custom-step-image-wrap">
            <div class="custom-step-num-badge">4</div>
            <img src="/images/4.jpg" alt="Choose Packaging — PET bags, paper boxes, tin boxes" loading="lazy" />
          </div>
          <div class="custom-step-body">
            <h4>Choose Packaging</h4>
            <p>PET bags, paper boxes, tin boxes, or display cartons. We design artwork in-house or work with your designer. FSC-certified eco packaging available for sustainability-focused brands.</p>
          </div>
        </div>
      </div>

      <!-- Additional options -->
      <div class="oem-additional-options">
        <div class="oem-additional-option">
          <div class="addon-icon">🌿</div>
          <h5>Herbal Fragrance</h5>
          <p>Lavender, chamomile, eucalyptus, mint, and more</p>
        </div>
        <div class="oem-additional-option">
          <div class="addon-icon">✨</div>
          <h5>Collagen</h5>
          <p>Infused strips for skincare synergy</p>
