---
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  'name': 'Quanzhou Honglinkai New Material Co., Ltd.',
  'alternateName': 'HLK Nasal Strips',
  'url': 'https://en.hlknasalstrips.com',
  'logo': 'https://en.hlknasalstrips.com/favicon.svg',
  'contactPoint': {
    '@type': 'ContactPoint',
    'telephone': '+86-198-0595-7675',
    'contactType': 'sales',
    'availableLanguage': ['English', 'Chinese'],
    'areaServed': ['US', 'EU', 'BR', 'AU', 'NL', 'CA', 'PE', 'PL', 'GB', 'SG', 'IT'],
  },
  'sameAs': [
    'https://www.youtube.com/@HLKTape',
    'https://www.instagram.com/hlkgeorge/',
    'https://www.facebook.com/GeorgewuHLK',
    'https://www.linkedin.cn/incareer/in/george-wu-099504233/',
    'https://x.com/HLKTAPE',
  ],
  'address': {
    '@type': 'PostalAddress',
    'streetAddress': 'No.299 Xingxian Road',
    'addressLocality': 'Licheng District',
    'addressRegion': 'Quanzhou City',
    'addressCountry': 'CN',
  },
};

const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  'name': 'HLK Nasal Strips',
  'url': 'https://en.hlknasalstrips.com',
  'potentialAction': {
    '@type': 'SearchAction',
    'target': 'https://en.hlknasalstrips.com/?s={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const SITE = 'https://en.hlknasalstrips.com';
const LABELS: Record<string, string> = {
  'products': 'Products',
  'oem': 'OEM / Private Label',
  'about': 'About Us',
  'trust': 'Trust & Safety',
  'contact': 'Contact',
  'faq': 'FAQ',
  'blog': 'Blog',
  'privacy': 'Privacy Policy',
  'terms': 'Terms & Conditions',
  'NasalDilator': 'Nasal Dilator',
  'ClassicNasalStrips': 'Classic Nasal Strips',
};

// Auto-generate BreadcrumbList from the current URL path
const segments = Astro.url.pathname.split('/').filter(Boolean);
let breadcrumb: any = null;
if (segments.length > 0) {
  const trail = [{ name: 'Home', url: SITE + '/' }];
  let acc = SITE;
  for (const seg of segments) {
    acc += '/' + seg;
    const name = LABELS[seg] ?? seg.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
    trail.push({ name, url: acc + '/' });
  }
  breadcrumb = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: trail.map((item: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: item.url,
    })),
  };
}
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)}></script>
{ breadcrumb && <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)}></script> }
